{
  "header_graud": {
    "prefix": "header_graud",
    "body": [
      "#ifndef __${1:TM_FILENAME}_H__",
      "#define __${1:TM_FILENAME}_H__",
      "",
      "$0",
      "",
      "#endif // !__${1:TM_FILENAME}_H__"
    ],
    "description": "Header file guard"
  },
  "commet_func": {
    "prefix": "/**",
    "body": [
      "/*",
      " * ${1:func_name}",
      " *",
      " * Desc: $2",
      " * In: $3",
      " * Ret: $4",
      " */"
    ],
    "description": "Function comment block"
  },
  "off-cf": {
    "prefix": "// clang-",
    "body": [
      "// clang-format off",
      "$1",
      "// clang-format on"
    ],
    "description": "Turn off clang-format temporary"
  }
}
